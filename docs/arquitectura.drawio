          <mxGeometry x="1260" y="95" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="dbp" value="DBpedia&#10;(fallback fuente)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1260" y="160" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="openai" value="OpenAI gpt-4o-mini&#10;(fallback: resumidor fake)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1260" y="225" width="180" height="50" as="geometry" />
