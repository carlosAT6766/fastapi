<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram id="resumeai-arch" name="ResumeAI - Arquitectura">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ResumeAI — Arquitectura (FastAPI hexagonal · Redis · WebSockets · RPA)" style="text;html=1;fontSize=18;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- CLIENTS -->
        <mxCell id="lbl_clients" value="Frontends (React + MUI)" style="text;html=1;fontSize=11;fontStyle=2;fontColor=#666666;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="admin" value="Frontend Admin&#10;:5173&#10;(gestión de libros / ventas)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="tienda" value="Frontend Tienda&#10;:5174&#10;(storefront público)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="rpa" value="RPA bot&#10;(Playwright / Chromium)&#10;on-demand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="190" height="80" as="geometry" />
        </mxCell>

        <!-- EDGE / LB -->
        <mxCell id="nginx" value="Nginx&#10;:8080&#10;Balanceador round-robin&#10;+ upgrade WebSocket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="320" y="190" width="180" height="120" as="geometry" />
        </mxCell>

        <!-- BACKEND: API GROUP -->
        <mxCell id="api_group" value="API — FastAPI hexagonal (3 réplicas)&#10;contextos: auth · transactions · assistant · settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontStyle=1;spacingTop=6;" vertex="1" parent="1">
