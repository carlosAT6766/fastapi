        <!-- EDGES: clients -> nginx -->
        <mxCell id="e_admin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;strokeColor=#6c8ebf;" edge="1" parent="1" source="admin" target="nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_admin_lbl" value="HTTP + WS /transactions/stream" style="edgeLabel;html=1;fontSize=10;" connectable="0" vertex="1" parent="e_admin">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_tienda" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;strokeColor=#6c8ebf;" edge="1" parent="1" source="tienda" target="nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_tienda_lbl" value="HTTP + WS /storefront/stream" style="edgeLabel;html=1;fontSize=10;" connectable="0" vertex="1" parent="e_tienda">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- nginx -> api group -->
        <mxCell id="e_nginx_api" value="round-robin" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;fontSize=10;strokeColor=#82b366;" edge="1" parent="1" source="nginx" target="api_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- rpa -> nginx & wiki -->
        <mxCell id="e_rpa_nginx" value="login + /assistant/summarize" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#d79b00;" edge="1" parent="1" source="rpa" target="nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_rpa_wiki" value="Playwright (abre Wikipedia)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#d79b00;dashed=1;" edge="1" parent="1" source="rpa" target="wiki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- api -> pg / redis -->
        <mxCell id="e_api_pg" value="SQLAlchemy async" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;fontSize=10;strokeColor=#b85450;" edge="1" parent="1" source="api_group" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_api_redis" value="encola job / publica eventos" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#b85450;" edge="1" parent="1" source="api_group" target="redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_redis_api" value="pub/sub → WebSocket" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="redis" target="api_group">
          <mxGeometry relative="1" as="geometry"><mxPoint x="900" y="60" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- worker edges -->
        <mxCell id="e_worker_redis" value="consume cola / publica estados" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;startArrow=classic;fontSize=10;strokeColor=#9673a6;" edge="1" parent="1" source="worker" target="redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_worker_pg" value="actualiza estado + resumen" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#9673a6;" edge="1" parent="1" source="worker" target="pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_worker_wiki" value="fetch párrafo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#d6b656;" edge="1" parent="1" source="worker" target="wiki">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_worker_dbp" value="fallback" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#d6b656;" edge="1" parent="1" source="worker" target="dbp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_worker_openai" value="resume párrafo" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;strokeColor=#d6b656;" edge="1" parent="1" source="worker" target="openai">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- legend -->
        <mxCell id="legend" value="Flujo tiempo real:&#10;1) Admin crea libro → API encola en Redis → Worker (RPA+IA) actualiza estados → publica en tx:user:{id} → WS → Admin en vivo.&#10;2) Admin publica libro → API publica en canal 'storefront' → WS /storefront/stream → Tienda refresca catálogo solo.&#10;3) Cliente compra en Tienda → venta idempotente (Idempotency-Key + UNIQUE) → publica al vendedor → WS → Admin ve la venta en vivo." style="text;html=1;whiteSpace=wrap;fontSize=11;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#cccccc;rounded=1;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="1120" height="120" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
