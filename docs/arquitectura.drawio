        </mxCell>
        <mxCell id="api3" value="api-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;" vertex="1" parent="api_group">
          <mxGeometry x="20" y="130" width="200" height="35" as="geometry" />
        </mxCell>

        <!-- WORKER -->
        <mxCell id="worker" value="Worker (arq)&#10;Pipeline libro:&#10;buscando → resumiendo → listo/fallido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
